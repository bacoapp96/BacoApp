<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Cuenta - BacoApp</title>
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/cuenta.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>
<body>

<%- include("partials/client-sidebar", { active: "cuenta" }) %>

<main class="cuenta-container">
    <section class="account-hero">
        <div class="profile-card">
            <div class="profile-avatar" aria-hidden="true">
                <img src="/img/logo_bacoapp.png" alt="BacoApp">
            </div>
            <div>
                <span class="account-kicker">Cuenta cliente</span>
                <h1 id="profileName">Juan Perez</h1>
                <p id="profileTier">Cliente Premium</p>
                <div class="perfil-badges">
                    <span><i class="fa-solid fa-circle-check"></i> Activo</span>
                    <span><i class="fa-solid fa-bag-shopping"></i> +12 pedidos</span>
                    <span><i class="fa-solid fa-coins"></i> 1.250 puntos</span>
                </div>
            </div>
        </div>

        <div class="hero-actions">
            <a class="btn-outline" href="/carrito">
                <i class="fa-solid fa-cart-shopping"></i>
                Ver carrito
                <span data-cart-count>0</span>
            </a>
            <button class="btn-editar-perfil" id="editProfile" type="button">
                <i class="fa-solid fa-pen"></i>
                Editar perfil
            </button>
        </div>
    </section>

    <section class="account-dashboard">
        <article class="metric-card">
            <i class="fa-solid fa-bag-shopping"></i>
            <span>Pedidos</span>
            <strong>12</strong>
        </article>
        <article class="metric-card">
            <i class="fa-solid fa-heart"></i>
            <span>Favoritos</span>
            <strong>24</strong>
        </article>
        <article class="metric-card">
            <i class="fa-solid fa-coins"></i>
            <span>Puntos</span>
            <strong>1.250</strong>
        </article>
        <article class="metric-card">
            <i class="fa-solid fa-crown"></i>
            <span>Nivel</span>
            <strong>Premium</strong>
        </article>
    </section>

    <section class="cuenta-grid">
        <article class="card-cuenta account-main">
            <div class="card-header">
                <div>
                    <h2>Informacion personal</h2>
                    <p>Datos principales para compras y entregas.</p>
                </div>
                <i class="fa-solid fa-user"></i>
            </div>

            <div class="form-grid">
                <div class="campo">
                    <label for="accountName">Nombre</label>
                    <input type="text" id="accountName" value="Juan Perez">
                </div>

                <div class="campo">
                    <label for="accountEmail">Email</label>
                    <input type="email" id="accountEmail" value="juan@gmail.com">
                </div>

                <div class="campo">
                    <label for="accountPhone">Telefono</label>
                    <input type="text" id="accountPhone" value="3210000000">
                </div>

                <div class="campo">
                    <label for="accountDocument">Documento</label>
                    <input type="text" id="accountDocument" value="CC 1000000000">
                </div>
            </div>

            <button class="btn-guardar" id="saveAccount" type="button">
                <i class="fa-solid fa-floppy-disk"></i>
                Guardar cambios
            </button>
        </article>

        <article class="card-cuenta">
            <div class="card-header">
                <div>
                    <h2>Apariencia</h2>
                    <p>Personaliza tu experiencia.</p>
                </div>
                <i class="fa-solid fa-palette"></i>
            </div>

            <div class="theme-selector" id="clientThemeSelector">
                <button type="button" data-theme-option="dark"><span class="swatch dark"></span> Oscuro</button>
                <button type="button" data-theme-option="gold"><span class="swatch gold"></span> Dorado</button>
                <button type="button" data-theme-option="neon"><span class="swatch neon"></span> Neon</button>
                <button type="button" data-theme-option="minimal"><span class="swatch minimal"></span> Minimal</button>
            </div>
        </article>

        <article class="card-cuenta">
            <div class="card-header">
                <div>
                    <h2>Seguridad</h2>
                    <p>Acceso y dispositivos.</p>
                </div>
                <i class="fa-solid fa-lock"></i>
            </div>

            <button class="btn-secundario" id="changePassword" type="button">
                <i class="fa-solid fa-key"></i> Cambiar contrasena
            </button>
            <button class="btn-secundario" id="showDevices" type="button">
                <i class="fa-solid fa-desktop"></i> Ver dispositivos conectados
            </button>
            <button class="btn-danger" id="deleteAccount" type="button">
                <i class="fa-solid fa-triangle-exclamation"></i> Eliminar cuenta
            </button>
        </article>

        <article class="card-cuenta">
            <div class="card-header">
                <div>
                    <h2>Direccion principal</h2>
                    <p>Usada para calcular entregas.</p>
                </div>
                <i class="fa-solid fa-location-dot"></i>
            </div>

            <div class="direccion-card" id="addressCard">
                <h3>Casa</h3>
                <p>Calle 20 # 10 - 30</p>
            </div>

            <button class="btn-agregar" id="addAddress" type="button">
                <i class="fa-solid fa-plus"></i> Actualizar direccion
            </button>
        </article>

        <article class="card-cuenta">
            <div class="card-header">
                <div>
                    <h2>Metodo de pago</h2>
                    <p>Pago favorito para compras rapidas.</p>
                </div>
                <i class="fa-solid fa-credit-card"></i>
            </div>

            <div class="pago-card" id="paymentCard">
                <i class="fa-brands fa-cc-visa"></i>
                <span>**** 4589</span>
            </div>

            <button class="btn-agregar" id="addPayment" type="button">
                <i class="fa-solid fa-plus"></i> Actualizar tarjeta
            </button>
        </article>
    </section>

    <section class="historial-card">
        <div class="card-header">
            <div>
                <h2>Historial y actividad</h2>
                <p>Seguimiento rapido de pedidos recientes.</p>
            </div>
            <i class="fa-solid fa-clock-rotate-left"></i>
        </div>

        <div class="pedido-list">
            <div class="pedido-item">
                <div>
                    <h3>Pedido #2045</h3>
                    <p>24 Mayo 2026 - Whisky premium y snacks</p>
                </div>
                <span class="estado entregado">Entregado</span>
            </div>

            <div class="pedido-item">
                <div>
                    <h3>Pedido #2046</h3>
                    <p>27 Mayo 2026 - Ron, gaseosas y hielo</p>
                </div>
                <span class="estado proceso">En proceso</span>
            </div>
        </div>
    </section>
</main>

<script src="/js/cart.js"></script>
<script src="/js/sidebar.js"></script>
<script src="/js/cuenta.js"></script>

</body>
</html>
