<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Busqueda-BacoApp</title>
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/busqueda.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>
<body>
  <script src="/js/theme.js"></script>

  <!-- BOTÓN MENÚ -->
  <button id="menu-btn" class="menu-btn">☰</button>
  <div id="overlay" class="overlay"></div>

  <!-- SIDEBAR MENÚ -->
  <aside id="sidebar" class="sidebar">
    <button id="close-btn" class="close-btn">✕</button>
    <h2 class="brand">BacoApp</h2>
    <nav class="nav">
      <ul>
        <li><a href="/Inicio"><i class="fa-solid fa-house"></i> Inicio</a></li>
        <li><a href="/Categorias"><i class="fa-solid fa-wine-bottle"></i> Categorias</a></li>
        <li><a href="#carrito"><i class="fa-solid fa-cart-shopping"></i> Carrito <span data-cart-count>0</span></a></li>
        <li><a href="/Cuenta"><i class="fa-solid fa-user"></i> Cuenta</a></li>
        <li><a href="/Index"><i class="fa-solid fa-right-from-bracket"></i> Cerrar sesion</a></li>
      </ul>
    </nav>
  </aside>

  <!-- CART SIDEBAR -->
  <aside id="cart-sidebar" class="cart-sidebar">
    <button class="close-cart">✕</button>
    <h2>Tu Carrito</h2>
    <div class="cart-items">
      <div id="carrito-contenido"></div>
    </div>
    <div class="cart-actions">
      <p id="total-price">Total: $0</p>
      <a class="cart-page-link" href="/carrito"><i class="fa-solid fa-up-right-from-square"></i> Ver carrito completo</a>
      <button id="btn-pagar">Pagar</button>
      <button id="btn-vaciar">Vaciar Carrito</button>
      <button id="btn-seguir">Seguir Comprando</button>
    </div>
  </aside>

<h1>🔍 Buscar Productos</h1>

<input type="text" placeholder="Busca whisky, ron, cerveza..." class="search-box">

<div class="results">

    <% productos.forEach(producto => { %>

        <div class="result-item">
            <h3><%= producto.Nombre %></h3>
            <p><%= producto.Descripcion %></p>
            <strong>$<%= producto.Precio %></strong>
            <button class="btn-agregar" data-nombre="<%= producto.Nombre %>" data-precio="<%= producto.Precio %>">Agregar al carrito</button>
        </div>

    <% }) %>

</div>

  <script src="/js/sidebar.js"></script>
  <script src="/js/cart.js"></script>
</body>
</html>
