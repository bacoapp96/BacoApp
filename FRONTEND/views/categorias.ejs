
<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>
        Categorías - BacoApp
    </title>

    <link rel="stylesheet" href="/css/global.css">

    <link rel="stylesheet" href="/css/categorias.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

</head>

<body>
    <script src="/js/theme.js"></script>

    <!-- BOTÓN MENÚ -->

    <button id="menu-btn" class="menu-btn">
        ☰
    </button>

    <!-- OVERLAY -->

    <div id="overlay" class="overlay"></div>

    <!-- SIDEBAR -->

    <aside id="sidebar" class="sidebar">

        <div class="sidebar-top">

            <h2 class="brand">
                BacoApp
            </h2>

            <button id="close-btn" class="close-btn">
                ✕
            </button>

        </div>

        <nav class="nav">

            <ul>

                <li>
                    <a href="/Inicio">
                        <i class="fa-solid fa-house"></i> Inicio
                    </a>
                </li>

                <li class="active">
                    <a href="/Categorias">
                        <i class="fa-solid fa-wine-bottle"></i> Categorias
                    </a>
                </li>

                <li>
                    <a href="#carrito">
                        <i class="fa-solid fa-cart-shopping"></i> Carrito <span data-cart-count>0</span>
                    </a>
                </li>

                <li>
                    <a href="/Cuenta">
                        <i class="fa-solid fa-user"></i> Cuenta
                    </a>
                </li>

                <li>
                    <a href="/Index">
                        <i class="fa-solid fa-right-from-bracket"></i> Cerrar sesion
                    </a>
                </li>

            </ul>

        </nav>

    </aside>

    <!-- CARRITO -->

    <aside id="cart-sidebar" class="cart-sidebar">

        <button class="close-cart">
            ✕
        </button>

        <h2>
            Tu Carrito
        </h2>

        <div class="cart-items">

            <div id="carrito-contenido"></div>

        </div>

        <div class="cart-actions">

            <p id="total-price">
                Total: $0
            </p>

            <a class="cart-page-link" href="/carrito">
                <i class="fa-solid fa-up-right-from-square"></i> Ver carrito completo
            </a>

            <button id="btn-pagar">
                Pagar
            </button>

            <button id="btn-vaciar">
                Vaciar Carrito
            </button>

            <button id="btn-seguir">
                Seguir Comprando
            </button>

        </div>

    </aside>

    <!-- MAIN -->

    <main class="categories-main">

        <!-- HEADER -->

        <section class="categories-header">

            <h1>
                Explora nuestras categorías
            </h1>

            <p>
                Encuentra bebidas premium y productos exclusivos.
            </p>

        </section>

        <!-- SEARCH -->

        <div class="search">

            <input
                type="text"
                placeholder="Buscar categorías..."
            >

            <button class="search-btn">
                🔍
            </button>

        </div>

        <!-- GRID -->

        <section class="category">

            <!-- VINOS -->

            <a class="category-card" href="categoria-vinos.html">

                <img
                    src="img/vinosSeleccionados.jpg"
                    alt="Vinos"
                >

                <div class="card-info">

                    <h3>Vinos</h3>

                    <span>
                        Premium Selection
                    </span>

                </div>

            </a>

            <!-- WHISKYS -->

            <a class="category-card" href="categoria-whisky.html">

                <img
                    src="img/whiskys.jpg"
                    alt="Whiskys"
                >

                <div class="card-info">

                    <h3>Whiskys</h3>

                    <span>
                        Top Brands
                    </span>

                </div>

            </a>

            <!-- RONES -->

            <a class="category-card" href="categoria-rones.html">

                <img
                    src="img/rones.jpg"
                    alt="Rones"
                >

                <div class="card-info">

                    <h3>Rones</h3>

                    <span>
                        Ediciones Especiales
                    </span>

                </div>

            </a>

            <!-- CERVEZAS -->

            <a class="category-card" href="categoria-cervezas.html">

                <img
                    src="img/cervezas.jpg"
                    alt="Cervezas"
                >

                <div class="card-info">

                    <h3>Cervezas</h3>

                    <span>
                        Importadas
                    </span>

                </div>

            </a>

            <!-- TEQUILAS -->

            <a class="category-card" href="categoria-tequilas.html">

                <img
                    src="img/tequilas.jpg"
                    alt="Tequilas"
                >

                <div class="card-info">

                    <h3>Tequilas</h3>

                    <span>
                        Premium Drinks
                    </span>

                </div>

            </a>

            <!-- AGUARDIENTES -->

            <a class="category-card" href="categoria-aguardientes.html">

                <img
                    src="img/aguardientes.jpg"
                    alt="Aguardientes"
                >

                <div class="card-info">

                    <h3>Aguardientes</h3>

                    <span>
                        Tradición Colombiana
                    </span>

                </div>

            </a>

            <!-- GASEOSAS -->

            <a class="category-card" href="categoria-gaseosas.html">

                <img
                    src="img/gaseosas.jpg"
                    alt="Gaseosas"
                >

                <div class="card-info">

                    <h3>Gaseosas</h3>

                    <span>
                        Refrescantes
                    </span>

                </div>

            </a>

            <!-- JUGOS -->

            <a class="category-card" href="categoria-jugos.html">

                <img
                    src="img/jugos.jpg"
                    alt="Jugos"
                >

                <div class="card-info">

                    <h3>Jugos</h3>

                    <span>
                        Sabores Naturales
                    </span>

                </div>

            </a>

            <!-- VODKAS -->

            <a class="category-card" href="categoria-vodkas.html">

                <img
                    src="img/vodkas.jpg"
                    alt="Vodkas"
                >

                <div class="card-info">

                    <h3>Vodkas</h3>

                    <span>
                        Luxury Collection
                    </span>

                </div>

            </a>

            <!-- GINEBRAS -->

            <a class="category-card" href="categoria-ginebras.html">

                <img
                    src="img/ginebras.jpg"
                    alt="Ginebras"
                >

                <div class="card-info">

                    <h3>Ginebras</h3>

                    <span>
                        Botánicos Premium
                    </span>

                </div>

            </a>

            <!-- DESECHABLES -->

            <a class="category-card" href="categoria-desechables.html">

                <img
                    src="img/desechables.jpg"
                    alt="Desechables"
                >

                <div class="card-info">

                    <h3>Desechables</h3>

                    <span>
                        Todo para tus eventos
                    </span>

                </div>

            </a>

            <!-- DULCES -->

            <a class="category-card" href="categoria-dulces.html">

                <img
                    src="img/dulces.jpg"
                    alt="Dulces"
                >

                <div class="card-info">

                    <h3>Dulces</h3>

                    <span>
                        Snacks y golosinas
                    </span>

                </div>

            </a>

            <!-- ACCESORIOS -->

            <a class="category-card" href="categoria-accesorios.html">

                <img
                    src="img/accesorios.jpg"
                    alt="Accesorios"
                >

                <div class="card-info">

                    <h3>Accesorios</h3>

                    <span>
                        Complementos premium
                    </span>

                </div>

            </a>

        </section>

    </main>

    <script src="/js/sidebar.js"></script>
    <script src="/js/cart.js"></script>

    <script src="/js/categorias.js"></script>

</body>

</html>
